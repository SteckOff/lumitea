# Web client (Vite — these are sent to the browser, only put safe values here)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server-side (NEVER expose to the browser)
# Used by backend/supabase/seed/*.ts:
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Edge Function secrets — set via `supabase secrets set ...`, not in this file.
# Listed here only for reference:
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   FCM_PROJECT_ID=lumitea-xxxxx
#   FCM_SERVICE_ACCOUNT_JSON={...}
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=lumitea.kr@gmail.com
#   SMTP_PASS=app-password
#   MAIL_FROM="Lumi Tea <lumitea.kr@gmail.com>"
#   CONTACT_TO=lumitea.kr@gmail.com
